// POST
// // ============================================

### Nowe zamówienie (serwer produktów na porcie 3000 musi działać)
POST http://localhost:3001/orders
Content-Type: application/json

{
    "customer_id": 1,
    "items": [
        { "product_id": 12, "quantity": 2 },
        { "product_id": 11, "quantity": 1 }
    ]
}

### Nieistniejący klient - błąd walidacji
POST http://localhost:3001/orders
Content-Type: application/json

{
    "customer_id": 9999,
    "items": [
        { "product_id": 1, "quantity": 1 }
    ]
}

### Nieistniejący produkt - błąd walidacji
POST http://localhost:3001/orders
Content-Type: application/json

{
    "customer_id": 1,
    "items": [
        { "product_id": 9999, "quantity": 2 }
    ]
}

### Przekroczony stan magazynowy - błąd walidacji
POST http://localhost:3001/orders
Content-Type: application/json

{
    "customer_id": 1,
    "items": [
        { "product_id": 12, "quantity": 1000 }
    ]
}

### Ujemna ilość produktu - błąd walidacji
POST http://localhost:3001/orders
Content-Type: application/json

{
    "customer_id": 1,
    "items": [
        { "product_id": 12, "quantity": -5 }
    ]
}

### Zerowa ilość produktu - błąd walidacji
POST http://localhost:3001/orders
Content-Type: application/json

{
    "customer_id": 1,
    "items": [
        { "product_id": 12, "quantity": 0 }
    ]
}

